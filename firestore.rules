rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helper functions ----
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDYPIUUser() {
      return isAuthenticated() && (
        request.auth.token.email.matches('.*@dypiu\\.ac\\.in') ||
        request.auth.token.email.matches('.*@dypiuinternational\\.ac\\.in')
      );
    }

    function isSecured() {
      return isAuthenticated() && isDYPIUUser();
    }

    function isSuperAdmin() {
      return isSecured() && (
        request.auth.token.roleLevel >= 5 ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleLevel >= 5)
      );
    }

    function isAdmin() {
      return isSecured() && (
        request.auth.token.roleLevel >= 3 ||
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleLevel >= 3)
      );
    }

    function isFaculty() {
        return isSecured() && (
            isAdmin() || 
            (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleLevel >= 2)
        );
    }

    // ---- COLLECTIONS ----

    match /users/{uid} {
      allow read: if isSecured();
      allow create: if isSecured() && request.auth.uid == uid 
        && request.resource.data.roleLevel == 1; // Default to Student
      allow update: if isSecured() && (
        (request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roleLevel', 'prn'])) ||
        isAdmin()
      );
      allow delete: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read, write: if isSecured() && (request.auth.uid == uid || isAdmin());
      }
    }

    match /channels/{id} {
      allow read: if isSecured();
      allow create: if isFaculty();
      allow update, delete: if isAdmin();

      match /messages/{mid} {
        allow read: if isSecured();
        allow create: if isSecured();
        allow update, delete: if isSecured() && (request.auth.uid == resource.data.senderId || isAdmin());
      }
    }

    match /quizzes/{id} {
      allow read: if isSecured();
      allow create: if isFaculty();
      allow update, delete: if isAdmin();

      match /submissions/{sid} {
        allow read: if isSecured() && (request.auth.uid == resource.data.userId || isAdmin());
        allow create: if isSecured() && request.resource.data.userId == request.auth.uid;
      }
    }

    match /announcements/{id} {
      allow read: if isSecured();
      allow write: if isFaculty();
    }

    match /placementDrives/{id} {
      allow read: if isSecured();
      allow write: if isAdmin();
    }

    match /grievances/{id} {
      allow read: if isSecured() && (request.auth.uid == resource.data.studentId || isFaculty());
      allow create: if isSecured();
      allow update: if isFaculty();
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if isSecured();
      allow update, delete: if false;
    }

    match /platformConfig/{id} {
      allow read: if isSecured();
      allow write: if isSuperAdmin();
    }
    
    match /resources/{id} {
        allow read: if isSecured();
        allow create: if isFaculty();
        allow update: if isSecured(); // Allow download count increment
        allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read: if isSecured();
      allow write: if isAdmin();
    }
  }
}
