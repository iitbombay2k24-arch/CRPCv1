rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helper functions ----
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDYPIUUser() {
      return isAuthenticated() && (
        request.auth.token.email.matches('.*@dypiu\\.ac\\.in') ||
        request.auth.token.email.matches('.*@dypiuinternational\\.ac\\.in')
      );
    }

    function userRole() {
      return request.auth.token.role != null 
        ? request.auth.token.role 
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStudentRole(data) {
      return !('role' in data) || data.role == 'Student';
    }

    // Secured = Authenticated + DYPIU domain  
    // NOTE: Email verification check REMOVED — it was blocking all reads
    // for users who registered but didn't verify. The frontend already
    // handles the verification gate in App.jsx.
    function isSecured() {
      return isAuthenticated() && isDYPIUUser();
    }

    // ---- USERS ----
    match /users/{uid} {
      // ALL authenticated DYPIU users can read ANY user profile
      // (needed for sidebar DMs, leaderboard, admin panel)
      allow read: if isSecured();
      allow create: if isAuthenticated() && isDYPIUUser() && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && isStudentRole(request.resource.data);
      // Users can update their own profile; admins can update any profile
      allow update: if isSecured() && (
        request.auth.uid == uid || userRole() in ['Admin', 'SuperAdmin']
      );
      allow delete: if false; 

      // Sub-collections under users
      match /notifications/{notifId} {
        allow read: if isSecured() && request.auth.uid == uid;
        allow create: if isSecured(); // System or other services can create
        allow update: if isSecured() && request.auth.uid == uid;
        allow delete: if isSecured() && request.auth.uid == uid;
      }
      
      match /bookmarks/{bookmarkId} {
        allow read, write: if isSecured() && request.auth.uid == uid;
      }

      match /drafts/{draftId} {
        allow read, write: if isSecured() && request.auth.uid == uid;
      }

      match /attendance/{attendanceId} {
        allow read: if isSecured() && request.auth.uid == uid;
        allow create: if isSecured();
      }

      match /focusSessions/{sessionId} {
        allow read: if isSecured() && request.auth.uid == uid;
        allow create: if isSecured() && request.auth.uid == uid;
      }
    }

    // ---- CHANNELS ----
    match /channels/{channelId} {
      allow read: if isSecured();
      allow create: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow update, delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];

      match /messages/{messageId} {
        allow read: if isSecured();
        allow create: if isSecured();
        allow update: if isSecured() && (
          request.auth.uid == resource.data.senderId ||
          userRole() in ['Faculty', 'Admin', 'SuperAdmin']
        );
        allow delete: if isSecured() && (
          request.auth.uid == resource.data.senderId ||
          userRole() in ['Admin', 'SuperAdmin']
        );
      }
    }

    // ---- DMs ----
    match /dms/{dmId} {
      allow read: if isSecured();
      allow create: if isSecured();
      allow update: if isSecured();

      match /messages/{messageId} {
        allow read: if isSecured();
        allow create: if isSecured();
        allow delete: if isSecured() && request.auth.uid == resource.data.senderId;
      }
    }

    // ---- AUDIT LOGS ----
    // Used by admin panel — collection name is 'auditLogs' 
    match /auditLogs/{logId} {
      allow read: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
      allow create: if isSecured(); // Services write audit entries
      allow update, delete: if false;
    }
    // Cloud Functions use 'auditLog' (no 's') — also add that
    match /auditLog/{logId} {
      allow read: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
      allow write: if false; // Cloud Functions only
    }

    // ---- ANNOUNCEMENTS ----
    match /announcements/{announcementId} {
      allow read: if isSecured();
      allow create: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- RESOURCES ----
    match /resources/{resourceId} {
      allow read: if isSecured();
      allow create: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow update: if isSecured(); // download count tracking
      allow delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- ATTENDANCE (top-level) ----
    match /attendance/{attendanceId} {
      allow read: if isSecured();
      allow create: if isSecured();
    }

    // ---- GRIEVANCES ----
    match /grievances/{ticketId} {
      allow read: if isSecured();
      allow create: if isSecured();
      allow update: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
    }

    // ---- Q&A ----
    match /questions/{questionId} {
      allow read: if isSecured();
      allow create: if isSecured();
      allow update: if isSecured();
      allow delete: if isSecured() && (request.auth.uid == resource.data.authorId || userRole() in ['Admin', 'SuperAdmin']);

      match /answers/{answerId} {
        allow read: if isSecured();
        allow create: if isSecured();
        allow update, delete: if isSecured() && (request.auth.uid == resource.data.authorId || userRole() in ['Admin', 'SuperAdmin']);
      }
    }

    // ---- TIMETABLE ----
    match /timetable/{slotId} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
    }

    // ---- BOARD TASKS ----
    match /boardTasks/{taskId} {
      allow read: if isSecured();
      allow create: if isSecured();
      allow update: if isSecured();
      allow delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- QUIZZES ----
    match /quizzes/{quizId} {
      allow read: if isSecured();
      allow create: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow update, delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];

      match /submissions/{subId} {
        allow read: if isSecured();
        allow create: if isSecured() && request.resource.data.userId == request.auth.uid;
      }

      match /results/{resultId} {
        allow read: if isSecured();
        allow create: if isSecured();
      }
    }

    // ---- PLACEMENT DRIVES ----
    match /placementDrives/{driveId} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];

      match /applications/{appId} {
        allow read: if isSecured();
        allow create: if isSecured();
      }
    }

    // ---- PLACEMENT STATS (Admin-managed) ----
    match /platformStats/{id} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- INTERVIEW EXPERIENCES ----
    match /interviewExperiences/{id} {
      allow read: if isSecured();
      allow create: if isSecured();
      allow update: if isSecured(); // Voting
      allow delete: if isSecured() && (request.auth.uid == resource.data.authorId || userRole() in ['Admin', 'SuperAdmin']);
    }

    // ---- SYLLABUS TRACKER ----
    match /syllabus/{id} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
    }

    // ---- PLATFORM CONFIG ----
    match /platformConfig/{id} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- PLACEMENT STATS (seeded) ----
    match /placementStats/{id} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- LEADERBOARD ----
    match /leaderboard/{entry} {
      allow read: if isSecured();
      allow write: if false; // Cloud Functions only
    }

    // ---- TYPING INDICATORS ----
    match /typing/{id} {
      allow read, write: if isSecured();
    }

    // ---- BLOGS ----
    match /blogs/{id} {
      allow read: if isSecured();
      allow create: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow update, delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }
  }
}
