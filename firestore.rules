rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helper functions ----
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isDYPIUUser() {
      return isAuthenticated() && (
        request.auth.token.email.matches('.*@dypiu\\.ac\\.in') ||
        request.auth.token.email.matches('.*@dypiuinternational\\.ac\\.in') ||
        // Allow any email during development — remove this line in production
        request.auth.token.email.size() > 0
      );
    }

    function userRole() {
      return request.auth.token.role != null 
        ? request.auth.token.role 
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Standard Auth + Domain + Verification Check
    function isSecured() {
      return isAuthenticated() && isDYPIUUser() && isEmailVerified();
    }

    // ---- USERS ----
    match /users/{uid} {
      allow read: if isAuthenticated() && isDYPIUUser() && (request.auth.uid == uid || (isEmailVerified() && userRole() in ['Admin', 'SuperAdmin']));
      allow create: if isAuthenticated() && isDYPIUUser() && request.auth.uid == uid;
      allow update: if isAuthenticated() && isDYPIUUser() && (
        // User can update their own profile (but not change their own role)
        (request.auth.uid == uid && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) ||
        // Admins can update any user's role and roleLevel
        (isSecured() && userRole() in ['Admin', 'SuperAdmin'])
      );
      allow delete: if false; 

      match /notifications/{notifId} {
        allow read: if isSecured() && request.auth.uid == uid;
        // Allow client to write their own notifications (until Cloud Functions are set up)
        allow write: if isSecured() && request.auth.uid == uid;
      }
      
      match /bookmarks/{bookmarkId} {
        allow read, write: if isSecured() && request.auth.uid == uid;
      }

      match /drafts/{draftId} {
        allow read, write: if isSecured() && request.auth.uid == uid;
      }

      match /attendance/{attendanceId} {
        allow read, write: if isSecured() && request.auth.uid == uid;
      }

      match /focusSessions/{sessionId} {
        allow read, write: if isSecured() && request.auth.uid == uid;
      }
    }

    function isAdmin() {
      return isSecured() && (
        request.auth.token.roleLevel >= 3 ||
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleLevel >= 3)
      );
    }

    function isFaculty() {
        return isSecured() && (
            isAdmin() || 
            (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roleLevel >= 2)
        );
    }

    // ---- COLLECTIONS ----

    match /users/{uid} {
      allow read: if isSecured();
      allow create: if isSecured() && request.auth.uid == uid 
        && request.resource.data.roleLevel == 1; // Default to Student
      allow update: if isSecured() && (
        (request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roleLevel', 'prn'])) ||
        isAdmin()
      );
      allow delete: if isSuperAdmin();

      match /{allSubcollections=**} {
        allow read, write: if isSecured() && (request.auth.uid == uid || isAdmin());
      }
    }

    // ---- DMs ----
    match /dms/{dmId} {
      allow read: if isSecured() && request.auth.uid in resource.data.participants;
      allow create: if isSecured() && request.auth.uid in request.resource.data.participants;
      allow update: if isSecured() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSecured() &&
          request.auth.uid in get(/databases/$(database)/documents/dms/$(dmId)).data.participants;
        allow create: if isSecured() &&
          request.auth.uid in get(/databases/$(database)/documents/dms/$(dmId)).data.participants;
        allow delete: if isSecured() && request.auth.uid == resource.data.senderId;
      }
    }

    // ---- AUDIT LOGS (fixed: was 'auditLog', service uses 'auditLogs') ----
    match /auditLogs/{logId} {
      allow read: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
      allow create: if isSecured(); // All secured users can create audit log entries
      allow update, delete: if false;
    }

    // ---- ANNOUNCEMENTS ----
    match /announcements/{announcementId} {
      allow read: if isSecured();
      allow create: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow update: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- RESOURCES ----
    match /resources/{resourceId} {
      allow read: if isSecured();
      allow create: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow update: if isSecured(); // To track meta like download counts
      allow delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- GRIEVANCES ----
    match /grievances/{ticketId} {
      allow read: if isSecured() && (
        userRole() in ['Faculty', 'Admin', 'SuperAdmin'] ||
        (!resource.data.isAnonymous && request.auth.uid == resource.data.authorId)
      );
      allow create: if isSecured() && (
        request.resource.data.isAnonymous == true || 
        request.resource.data.authorId == request.auth.uid
      );
      allow update: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
    }

    // ---- Q&A ----
    match /questions/{questionId} {
      allow read: if isSecured();
      allow create: if isSecured();
      allow update: if isSecured() && (request.auth.uid == resource.data.authorId || userRole() in ['Faculty', 'Admin', 'SuperAdmin']);
      allow delete: if isSecured() && (request.auth.uid == resource.data.authorId || userRole() in ['Admin', 'SuperAdmin']);

      match /answers/{answerId} {
        allow read: if isSecured();
        allow create: if isSecured();
        allow update, delete: if isSecured() && (request.auth.uid == resource.data.authorId || userRole() in ['Admin', 'SuperAdmin']);
      }
    }

    // ---- TIMETABLE ----
    match /timetable/{slotId} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
    }

    // ---- BOARD TASKS ----
    match /boardTasks/{taskId} {
      allow read: if isSecured();
      allow create: if isSecured();
      allow update, delete: if isSecured() && (
        request.auth.uid == resource.data.authorId || 
        request.auth.uid == resource.data.assignedTo ||
        userRole() in ['Admin', 'SuperAdmin']
      );
    }

    // ---- QUIZZES ----
    match /quizzes/{quizId} {
      allow read: if isSecured();
      allow create: if isSecured() && userRole() in ['Faculty', 'Admin', 'SuperAdmin'];
      allow update, delete: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];

      match /results/{resultId} {
        allow read: if isSecured() && (request.auth.uid == resource.data.userId || userRole() in ['Faculty', 'Admin', 'SuperAdmin']);
        allow create: if isSecured() && request.resource.data.userId == request.auth.uid;
      }
    }

    match /announcements/{id} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];

      match /applications/{appId} {
        allow read: if isSecured() && (request.auth.uid == appId || userRole() in ['Admin', 'SuperAdmin']);
        allow create: if isSecured() && request.auth.uid == appId;
      }
    }

    // ---- PLACEMENT STATS (admin-managed summary doc) ----
    match /placementStats/{docId} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- LEADERBOARD ----
    match /leaderboard/{entry} {
      allow read: if isSecured();
      allow write: if isSecured() && userRole() in ['Admin', 'SuperAdmin'];
    }

    // ---- INTERVIEW EXPERIENCES ----
    match /interviewExperiences/{expId} {
      allow read: if isSecured();
      allow create: if isSecured();
      allow update: if isSecured() && (request.auth.uid == resource.data.authorId || userRole() in ['Admin', 'SuperAdmin']);
      allow delete: if isSecured() && (request.auth.uid == resource.data.authorId || userRole() in ['Admin', 'SuperAdmin']);
    }

    // ---- STUDY ROOMS ----
    match /studyRooms/{roomId} {
      allow read, write: if isSecured();

      match /messages/{msgId} {
        allow read, write: if isSecured();
      }

      match /presence/{uid} {
        allow read: if isSecured();
        allow write: if isSecured() && request.auth.uid == uid;
      }
    }

    // ---- TYPING INDICATORS ----
    match /typing/{docId} {
      allow read, write: if isSecured();
    }
  }
}
